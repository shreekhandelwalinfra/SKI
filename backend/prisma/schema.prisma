// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USER & AUTH ─────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  phone       String   @default("")
  role        Role     @default(USER)
  uniqueId    String   @unique @default("")
  referralCode String  @unique @default("")
  status      UserStatus @default(PENDING)
  isBlocked   Boolean  @default(false)

  // Profile details
  address     String   @default("")
  city        String   @default("")
  state       String   @default("")
  pincode     String   @default("")
  panNumber   String   @default("")
  aadharNumber String  @default("")
  profileImage String  @default("")
  dateOfBirth  String  @default("")

  // Referral / Team (tree structure)
  referredById String?
  referredBy   User?    @relation("Referral", fields: [referredById], references: [id])
  referrals    User[]   @relation("Referral")

  teamLeadId   String?
  teamLead     User?    @relation("Team", fields: [teamLeadId], references: [id])
  teamMembers  User[]   @relation("Team")

  // Bonus tracking
  selfReward     Float   @default(0)
  directBonus    Float   @default(0)
  teamBonus      Float   @default(0)
  totalBusiness  Float   @default(0)   // selfInvestment + downlineVolume
  selfInvestment Float   @default(0)   // Direct volume (own money + client deals)
  downlineVolume Float   @default(0)   // Sum of all downline selfInvestment
  rank           Int     @default(0)   // 0 = unranked, 1-10 based on totalBusiness

  activatedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  investments     Investment[]
  profits         Profit[]
  supportTickets  SupportTicket[]
  inquiries       Inquiry[]
  bankDetail      BankDetail?
  propertyDeals   PropertyDeal[]
  rewards         Reward[]

  @@index([status])
  @@index([role])
  @@index([referredById])
  @@index([teamLeadId])
  @@index([referralCode])
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
}

// ─── BANK DETAIL ─────────────────────────────────────────

model BankDetail {
  id            String @id @default(cuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountHolder String @default("")
  accountNumber String @default("")
  ifscCode      String @default("")
  bankName      String @default("")
  branchName    String @default("")
  upiId         String @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── RANK SYSTEM ─────────────────────────────────────────

model RankConfig {
  id              String  @id @default(cuid())
  rank            Int     @unique
  teamBusinessMin Float              // Lower boundary (exclusive for rank>1)
  teamBusinessMax Float              // Upper boundary (inclusive, <= check)
  commissionPct   Float              // Rate as percentage (3, 5, 7, 9, etc.)
  selfInvestment  Float              // Required self-investment to qualify
  rewardName      String             // Physical reward name
  rewardValue     Float              // Physical reward value in INR

  @@index([rank])
}

// ─── PROPERTY DEAL & INSTALLMENTS ────────────────────────
// Tracks real estate deals and their staggered installment payments

model PropertyDeal {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  propertyName    String
  propertyType    String     @default("")
  totalDealAmount Float
  status          DealStatus @default(ACTIVE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  installments    Installment[]

  @@index([userId])
  @@index([status])
}

model Installment {
  id              String       @id @default(cuid())
  propertyDealId  String
  propertyDeal    PropertyDeal @relation(fields: [propertyDealId], references: [id], onDelete: Cascade)
  amount          Float                    // This installment amount
  rateAtPayment   Float        @default(0) // User's commission rate when processed
  directBonusPaid Float        @default(0) // Direct bonus amount paid for this installment
  transactionId   String
  processedAt     DateTime     @default(now())

  @@index([propertyDealId])
}

enum DealStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── PHYSICAL REWARDS ────────────────────────────────────
// Tracks which physical rewards a user has claimed (cumulative)

model Reward {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  rank        Int                        // Which rank reward (1-10)
  rewardName  String                     // e.g. "Mobile", "LED TV"
  rewardValue Float                      // Value in INR
  claimedAt   DateTime @default(now())

  @@unique([userId, rank])               // One reward per rank per user
  @@index([userId])
}

// ─── PROPERTY ────────────────────────────────────────────

model Property {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  category        PropertyCategory
  listingType     ListingType @default(SALE)
  price           Float
  priceUnit       String   @default("total")
  area            Float
  areaUnit        String   @default("sqft")

  // Location (flattened)
  address         String   @default("")
  city            String
  state           String   @default("Uttar Pradesh")
  pincode         String   @default("")
  zone            String   @default("")

  description     String   @default("")
  highlights      String[] @default([])
  amenities       String[] @default([])
  images          Json     @default("[]")

  isFeatured      Boolean  @default(false)
  isActive        Boolean  @default(true)
  isMVDAApproved  Boolean  @default(false)
  possession      String   @default("")
  facing          String   @default("")
  roadWidth       String   @default("")

  // Contact person (flattened)
  contactName     String   @default("")
  contactPhone    String   @default("")
  contactEmail    String   @default("")

  views           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category, isActive])
  @@index([isFeatured])
  @@index([city])
  @@index([price])
}

enum PropertyCategory {
  RESIDENTIAL_LAND
  COMMERCIAL_LAND
  MVDA_APPROVED
  MATHURA_VRINDAVAN
  NOIDA_GREATER_NOIDA_JEWAR
}

enum ListingType {
  SALE
  PURCHASE
}

// ─── BLOG ────────────────────────────────────────────────

model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  Json     @default("{}")
  author      String   @default("SKI Team")
  tags        String[] @default([])
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, createdAt])
}

// ─── INQUIRY ─────────────────────────────────────────────

model Inquiry {
  id            String       @id @default(cuid())
  name          String
  email         String
  phone         String
  message       String
  propertyId    String?
  propertyTitle String       @default("")
  status        InquiryStatus @default(NEW)

  userId        String?
  user          User?        @relation(fields: [userId], references: [id])

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum InquiryStatus {
  NEW
  CONTACTED
  CLOSED
}

// ─── INVESTMENT ──────────────────────────────────────────

model Investment {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  name            String                            // Investor name (auto-filled)
  uniqueId        String                            // User's SKI ID (auto-filled)
  amount          Float                              // Investment amount for this installment

  // Property details
  propertyName    String           @default("")      // e.g. "Green Valley Residency"
  plotAreaSize    String           @default("")      // e.g. "1200 sqft", "150 sqyd"
  propertyValue   Float            @default(0)       // Total property value
  propertyAddress String           @default("")      // Full property address
  installmentNo   String           @default("1")     // "1", "2", "3" or "Final"

  type            String           @default("")      // Legacy field
  transactionDate DateTime
  transactionId   String
  status          InvestmentStatus @default(PENDING)
  remarks         String           @default("")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([userId])
}

enum InvestmentStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── PROFIT ──────────────────────────────────────────────

model Profit {
  id                    String       @id @default(cuid())
  userId                String
  user                  User         @relation(fields: [userId], references: [id])
  type                  ProfitType
  amount                Float
  description           String       @default("")
  remark                String       @default("")
  status                ProfitStatus @default(PENDING)
  transactionId         String       @default("")

  // For team bonus: which teammate triggered it
  fromUserId            String?
  fromUserName          String       @default("")
  fromUserUniqueId      String       @default("")
  fromUserRank          Int          @default(0)
  differencePercentage  Float        @default(0)

  // For direct bonus
  investmentAmount      Float        @default(0)
  brokerage             Float        @default(0)
  commission            Float        @default(0)

  // Link to property deal installment
  propertyDealId        String?
  installmentId         String?

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([type])
  @@index([userId])
  @@index([status])
}

enum ProfitType {
  FIRM
  SELF_REWARD
  DIRECT_BONUS
  TEAM_BONUS
}

enum ProfitStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

// ─── SUPPORT TICKET ──────────────────────────────────────

model SupportTicket {
  id          String       @id @default(cuid())
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  name        String
  email       String
  subject     String
  message     String
  status      TicketStatus @default(OPEN)
  adminReply  String       @default("")
  messages    Json         @default("[]")
  lastSeenByAdmin DateTime?            // null = never seen by admin
  lastSeenByUser  DateTime?            // null = never seen by user (for read receipts)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([userId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}
