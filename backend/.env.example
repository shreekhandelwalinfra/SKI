# Backend Environment Variables
PORT=5000
NODE_ENV=development

# PostgreSQL (Supabase)
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gmail SMTP (for Email OTP Verification)
# Step 1: Create/use a dedicated Gmail account for the app (e.g. ski.admin@gmail.com)
# Step 2: Go to Google Account → Security → Enable 2-Step Verification
# Step 3: Search "App Passwords" → Create one → 16-character password
SMTP_EMAIL=ski.admin@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Frontend URL (for referral links, CORS)
FRONTEND_URL=http://localhost:3000
